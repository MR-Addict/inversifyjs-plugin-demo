{
  "name": "inversifyjs-plugin-demo",
  "version": "1.0.0",
  "packageManager": "pnpm@11.8.0",
  "private": true,
  "description": "Pure TypeScript + DOM API plugin demo powered by InversifyJS",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json && node scripts/build.mjs",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "serve": "node scripts/dev-server.mjs",
    "dev": "npm run build && npm run serve"
  },
  "keywords": [
    "inversify",
    "typescript",
    "plugins",
    "dom"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "inversify": "^8.1.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.0",
    "typescript": "^6.0.3"
  }
}
